---
import Layout from "../../layouts/Layout.astro";
import { SERVICES, type Service } from "../../data/services";
import Airplane from "phosphor-astro/Airplane.astro";
import Sailboat from "phosphor-astro/Sailboat.astro";
import Truck from "phosphor-astro/Truck.astro";
import Train from "phosphor-astro/Train.astro";
import ClipboardText from "phosphor-astro/ClipboardText.astro";
import HouseLine from "phosphor-astro/HouseLine.astro";
import Crane from "phosphor-astro/Crane.astro";
import Warehouse from "phosphor-astro/Warehouse.astro";
import ShieldCheck from "phosphor-astro/ShieldCheck.astro";
import Package from "phosphor-astro/Package.astro";
import FileText from "phosphor-astro/FileText.astro";
import Stack from "phosphor-astro/Stack.astro";
import ArrowsLeftRight from "phosphor-astro/ArrowsLeftRight.astro";

const iconMap = new Map<string, typeof Airplane>([
  ["Airplane", Airplane],
  ["Sailboat", Sailboat],
  ["Truck", Truck],
  ["Train", Train],
  ["ClipboardText", ClipboardText],
  ["HouseLine", HouseLine],
  ["Crane", Crane],
  ["Warehouse", Warehouse],
  ["ShieldCheck", ShieldCheck],
  ["Package", Package],
  ["FileText", FileText],
  ["Stack", Stack],
  ["ArrowsLeftRight", ArrowsLeftRight],
]);

export function getStaticPaths() {
  return SERVICES.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props as { service: Service };

const related = SERVICES.filter(s => s.slug !== service.slug).slice(0, 3);
---
<Layout title={`${service.name} — SHIVAAY LOGISTICS`} description={service.description.slice(0, 160)}>
  <section class="py-16 md:py-24 max-w-7xl mx-auto px-4">
    <nav class="text-sm text-stone mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-iron transition-colors">Home</a>
      <span class="mx-2" aria-hidden="true">›</span>
      <a href="/services" class="hover:text-iron transition-colors">Services</a>
      <span class="mx-2" aria-hidden="true">›</span>
      <span class="text-coal" aria-current="page">{service.name}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2">
        <div class="w-14 h-14 bg-iron/10 rounded-sm flex items-center justify-center mb-6" aria-hidden="true">
          {(() => {
            const IconComponent = iconMap.get(service.icon);
            return IconComponent && <IconComponent width={28} height={28} class="text-iron" />;
          })()}
        </div>
        <h1 class="text-3xl md:text-4xl font-display font-bold text-coal mb-4">{service.name}</h1>
        <p class="text-lg text-graphite leading-relaxed">{service.description}</p>

        <div class="mt-8 md:mt-10">
          <h2 class="text-xl font-display font-bold text-coal mb-4">Key Features</h2>
          <ul class="space-y-3">
            {service.details.map((d) => (
              <li class="flex items-start gap-3">
                <span class="w-1.5 h-1.5 bg-iron rounded-full mt-2 shrink-0" aria-hidden="true"></span>
                <span class="text-graphite">{d}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="mt-8 md:mt-10">
          <h2 class="text-xl font-display font-bold text-coal mb-4">How It Works</h2>
          <ol class="space-y-4">
            {service.process.map((p, i) => (
              <li class="flex items-start gap-4">
                <span class="w-8 h-8 bg-iron text-white rounded-sm flex items-center justify-center text-sm font-bold shrink-0">{i + 1}</span>
                <span class="text-graphite pt-1">{p}</span>
              </li>
            ))}
          </ol>
        </div>
        
        <div class="mt-8 flex gap-4">
          <a href="/get-quote" class="bg-iron text-white px-6 py-2.5 rounded-sm text-sm font-medium hover:bg-iron-dark transition-colors">Get a Quote</a>
          <a href="/contact" class="border border-iron text-iron px-6 py-2.5 rounded-sm text-sm font-medium hover:bg-iron hover:text-white transition-colors">Contact Us</a>
        </div>
      </div>

      <div class="bg-linen rounded-sm p-6">
        <h2 class="font-display font-semibold text-coal mb-4">Related Services</h2>
        <ul class="space-y-3">
          {related.map((s) => {
            const IconComponent = iconMap.get(s.icon);
            return (
            <li>
              <a href={`/services/${s.slug}`} class="flex items-center gap-3 text-sm text-graphite hover:text-iron transition-colors">
                <div class="w-6 h-6 bg-iron/10 rounded-sm flex items-center justify-center shrink-0" aria-hidden="true">
                  {IconComponent && <IconComponent width={12} height={12} class="text-iron" />}
                </div>
                {s.name}
              </a>
            </li>
          )})}
        </ul>
      </div>
    </div>
  </section>
</Layout>
