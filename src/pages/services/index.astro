---
import Layout from "../../layouts/Layout.astro";
import { SERVICES } from "../../data/services";
---
<Layout title="Our Services — SHIVAAY LOGISTICS">
  <section class="py-16 md:py-24 max-w-7xl mx-auto px-4">
    <nav class="text-sm text-stone mb-6">
      <a href="/" class="hover:text-iron transition-colors">Home</a>
      <span class="mx-2">›</span>
      <span class="text-coal">Our Services</span>
    </nav>
    <h1 class="text-3xl md:text-4xl font-display font-bold text-coal mb-4">Our Services</h1>
    <p class="text-graphite mb-12 max-w-2xl">Comprehensive logistics and customs brokerage solutions tailored to your business needs.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {SERVICES.map((service) => (
        <a
          href={`/services/${service.slug}`}
          class="group block bg-white border border-linen rounded-sm p-6 hover:border-iron transition-colors"
        >
          <div class="w-10 h-10 bg-iron/10 rounded-sm flex items-center justify-center mb-4" aria-hidden="true">
            <span class="text-iron text-lg font-bold" aria-hidden="true">{service.name.charAt(0)}</span>
          </div>
          <h2 class="text-lg font-display font-bold text-coal group-hover:text-iron transition-colors">{service.name}</h2>
          <p class="text-sm text-graphite mt-2">{service.shortDesc}</p>
          <span class="text-iron text-sm font-medium mt-3 inline-block">Learn more →</span>
        </a>
      ))}
    </div>
  </section>
</Layout>
