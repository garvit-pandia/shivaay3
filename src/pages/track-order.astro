---
import Layout from "../layouts/Layout.astro";
import TrackSearch from "../components/TrackSearch.tsx";
---
<Layout title="Track Order — SHIVAAY LOGISTICS" description="Track your shipment status in real-time. Enter your container or tracking number to get live updates on your cargo.">
  <section class="py-16 md:py-24 max-w-7xl mx-auto px-4">
    <nav class="text-sm text-stone mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-iron transition-colors">Home</a>
      <span class="mx-2" aria-hidden="true">›</span>
      <span class="text-coal" aria-current="page">Track Order</span>
    </nav>
    <div class="text-center mb-8">
      <h1 class="text-3xl md:text-4xl font-display font-bold text-coal mb-4">Track Your Shipment</h1>
      <p class="text-graphite max-w-xl mx-auto">Enter your container number or tracking ID to get real-time status updates on your shipment.</p>
    </div>
    <TrackSearch client:load />
  </section>
</Layout>
