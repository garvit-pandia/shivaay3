---
import Layout from "../layouts/Layout.astro";
import QuoteForm from "../components/QuoteForm.tsx";
---
<Layout title="Get a Quote — SHIVAAY LOGISTICS">
  <section class="py-16 md:py-24 max-w-7xl mx-auto px-4">
    <nav class="text-sm text-stone mb-6">
      <a href="/" class="hover:text-iron transition-colors">Home</a>
      <span class="mx-2">›</span>
      <span class="text-coal">Get a Quote</span>
    </nav>
    <div class="max-w-2xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-display font-bold text-coal mb-4">Get a Quote</h1>
      <p class="text-graphite mb-8">Fill in the details below and we'll provide you with a competitive quote within 24 hours.</p>
      <QuoteForm client:load />
    </div>
  </section>
</Layout>
