---
import Layout from "../layouts/Layout.astro";
import QuoteForm from "../components/QuoteForm.tsx";
---
<Layout title="Get a Quote — SHIVAAY LOGISTICS" description="Get a free quote for your logistics and shipping needs. We handle air, sea, road, and rail freight forwarding across India.">
  <section class="py-16 md:py-24 max-w-7xl mx-auto px-4">
    <nav class="text-sm text-stone mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-iron transition-colors">Home</a>
      <span class="mx-2" aria-hidden="true">›</span>
      <span class="text-coal" aria-current="page">Get a Quote</span>
    </nav>
    <div class="max-w-2xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-display font-bold text-coal mb-4">Get a Quote</h1>
      <p class="text-graphite">Fill in the details below and we'll provide you with a competitive quote within 24 hours.</p>
      <QuoteForm client:load />
    </div>
  </section>
</Layout>
