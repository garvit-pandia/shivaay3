---
import { STATS } from "../data/site";
---

<section class="bg-iron py-10 md:py-16">
  <dl class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-7xl mx-auto px-4">
    {STATS.map((stat) => (
      <div class="text-center md:text-left">
        <dt class="text-2xl md:text-4xl font-display font-bold">{stat.value}</dt>
        <dd class="text-sm font-medium mt-1 tracking-wider uppercase text-white/70">{stat.label}</dd>
      </div>
    ))}
  </dl>
</section>
