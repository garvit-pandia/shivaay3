---
import { SITE, NAV } from "../data/site";
import { SERVICES } from "../data/services";
import FacebookLogo from "phosphor-astro/FacebookLogo.astro";
import LinkedinLogo from "phosphor-astro/LinkedinLogo.astro";
import TwitterLogo from "phosphor-astro/TwitterLogo.astro";
import MapPin from "phosphor-astro/MapPin.astro";
import Phone from "phosphor-astro/Phone.astro";
import Envelope from "phosphor-astro/Envelope.astro";
import Clock from "phosphor-astro/Clock.astro";
---

<footer class="bg-coal text-white">
  <div class="max-w-7xl mx-auto px-4 py-10 grid lg:grid-cols-4 md:grid-cols-2 grid-cols-1 gap-6 md:gap-8">
    <div>
      <h3 class="font-display font-bold text-sm md:text-lg tracking-wider mb-4">{SITE.name}</h3>
      <p class="text-stone text-sm leading-relaxed mb-4 text-center sm:text-left">
        Your trusted customs broker & logistics facilitator
      </p>
      {SITE.social.facebook !== "#" && (
        <div class="flex items-center gap-3">
        <a href={SITE.social.facebook} class="text-stone hover:text-turmeric transition-colors" aria-label="Facebook">
          <FacebookLogo width={20} height={20} />
        </a>
        <a href={SITE.social.linkedin} class="text-stone hover:text-turmeric transition-colors" aria-label="LinkedIn">
          <LinkedinLogo width={20} height={20} />
        </a>
        <a href={SITE.social.twitter} class="text-stone hover:text-turmeric transition-colors" aria-label="Twitter">
          <TwitterLogo width={20} height={20} />
        </a>
      </div>
      )}
    </div>

    <div>
      <h4 class="font-display font-semibold text-sm uppercase tracking-wider mb-4">Quick Links</h4>
      <ul class="space-y-2.5">
        {NAV.map((item) => (
          <li class="py-1">
            <a href={item.href} class="text-stone text-sm hover:text-turmeric transition-colors">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="font-display font-semibold text-sm uppercase tracking-wider mb-4">Our Services</h4>
      <ul class="space-y-2.5">
        {SERVICES.slice(0, 6).map((service) => (
          <li class="py-1">
            <a href={`/services/${service.slug}`} class="text-stone text-sm hover:text-turmeric transition-colors">
              {service.name}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="font-display font-semibold text-sm uppercase tracking-wider mb-4">Contact</h4>
      <ul class="space-y-3">
        <li class="flex items-start gap-2.5">
          <MapPin width={18} height={18} class="mt-0.5 shrink-0 text-turmeric" aria-hidden="true" />
          <span class="text-stone text-sm">{SITE.address}</span>
        </li>
        <li>
          <a href={`tel:${SITE.phone[0].replace(/[^+\d]/g, "")}`} class="flex items-center gap-2.5 text-stone text-sm hover:text-turmeric transition-colors">
            <Phone width={18} height={18} class="shrink-0 text-turmeric" aria-hidden="true" />
            {SITE.phone[0]}
          </a>
        </li>
        <li>
          <a href={`tel:${SITE.phone[1].replace(/[^+\d]/g, "")}`} class="flex items-center gap-2.5 text-stone text-sm hover:text-turmeric transition-colors">
            <Phone width={18} height={18} class="shrink-0 text-turmeric" aria-hidden="true" />
            {SITE.phone[1]}
          </a>
        </li>
        <li>
          <a href={`mailto:${SITE.email}`} class="flex items-center gap-2.5 text-stone text-sm hover:text-turmeric transition-colors break-all">
            <Envelope width={18} height={18} class="shrink-0 text-turmeric" aria-hidden="true" />
            {SITE.email}
          </a>
        </li>
        <li class="flex items-start gap-2.5">
          <Clock width={18} height={18} class="mt-0.5 shrink-0 text-turmeric" aria-hidden="true" />
          <span class="text-stone text-sm">{SITE.hours}</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="bg-graphite py-4">
    <div class="max-w-7xl mx-auto px-4 text-center text-stone text-sm space-y-1">
      <p>&copy; {new Date().getFullYear()} {SITE.name}. All rights reserved.</p>
      <p class="text-xs text-stone/50">Photographs from Unsplash</p>
    </div>
  </div>
</footer>
