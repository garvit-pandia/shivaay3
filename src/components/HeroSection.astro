---
// Split layout: text left (col-lg-7), image right (col-lg-5)
---

<section class="relative min-h-[100dvh] flex items-center pb-16 md:pb-24">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center max-w-7xl mx-auto px-4 w-full">
    <div class="lg:col-span-7">
      <span class="hero-animate inline-block bg-iron/10 text-iron text-xs md:text-sm font-medium px-3 py-0.5 md:px-4 md:py-1 rounded-sm tracking-wider uppercase">
        LUDHIANA'S TRUSTED CUSTOMS BROKER
      </span>
      <h1 class="hero-animate text-3xl md:text-5xl lg:text-6xl font-display font-bold text-coal leading-tight mt-3 md:mt-4">
        Your Customs Broker & Logistics Partner
      </h1>
      <p class="hero-animate text-base md:text-lg text-graphite mt-3 md:mt-4 max-w-xl">
        End-to-end freight forwarding, customs clearance, and logistics solutions across India.
      </p>
      <div class="hero-animate flex flex-col sm:flex-row gap-3 mt-6 md:mt-8">
        <a href="/get-quote" class="inline-block bg-iron text-white px-6 sm:px-8 py-2.5 sm:py-3 rounded-sm text-sm md:text-base font-medium hover:bg-iron-dark transition-colors text-center">
          Get a Quote
        </a>
        <a href="/contact" class="inline-block border border-iron text-iron px-6 sm:px-8 py-2.5 sm:py-3 rounded-sm text-sm md:text-base font-medium hover:bg-iron hover:text-white transition-colors text-center">
          Contact Us
        </a>
      </div>
    </div>
    <div class="lg:col-span-5">
      <img src="/images/hero-cargo.jpg" alt="Cargo containers at a shipping port" class="w-full h-auto lg:h-full min-h-[250px] lg:min-h-[400px] object-cover rounded-sm" loading="eager" />
    </div>
  </div>
</section>
