---
// Split layout: text left (col-lg-7), image right (col-lg-5)
---

<section class="relative min-h-[100dvh]">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center max-w-7xl mx-auto px-4 pt-20 min-h-[100dvh]">
    <div class="lg:col-span-7">
      <span class="inline-block bg-iron/10 text-iron text-sm font-medium px-4 py-1 rounded-sm tracking-wider uppercase">
        LUDHIANA'S TRUSTED CUSTOMS BROKER
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold text-coal leading-tight mt-4">
        Your Customs Broker & Logistics Partner
      </h1>
      <p class="text-lg text-graphite mt-4 max-w-xl">
        End-to-end freight forwarding, customs clearance, and logistics solutions across India.
      </p>
      <div class="flex flex-wrap gap-4 mt-8">
        <a href="/get-quote" class="inline-block bg-iron text-white px-8 py-3 rounded-sm font-medium hover:bg-iron-dark transition-colors">
          Get a Quote
        </a>
        <a href="/contact" class="inline-block border border-iron text-iron px-8 py-3 rounded-sm font-medium hover:bg-iron hover:text-white transition-colors">
          Contact Us
        </a>
      </div>
    </div>
    <div class="lg:col-span-5">
      <img src="/images/hero-cargo.jpg" alt="Cargo containers at a shipping port" class="w-full h-full min-h-[400px] object-cover rounded-sm" width="1200" height="800" loading="eager" />
    </div>
  </div>
</section>
